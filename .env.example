# AegisScan Environment Configuration
# Copy this file to .env and customize for your environment

# Database Configuration
# SQLite: sqlite:///aegisscan.db
# PostgreSQL: postgresql://user:password@localhost/aegisscan
# MySQL: mysql+pymysql://user:password@localhost/aegisscan
AEGISSCAN_DB_URL=sqlite:///aegisscan.db

# External Intelligence API Keys
# Shodan (https://www.shodan.io)
SHODAN_API_KEY=

# Censys (https://censys.io)
CENSYS_API_ID=
CENSYS_API_SECRET=

# Logging Configuration
# Levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
AEGISSCAN_LOG_LEVEL=INFO

# Scanning Configuration
# Default rate limit (0 = unlimited)
AEGISSCAN_RATE_LIMIT=0

# Default concurrency level
AEGISSCAN_CONCURRENCY=200

# Web Server Configuration
AEGISSCAN_WEB_HOST=127.0.0.1
AEGISSCAN_WEB_PORT=8080
AEGISSCAN_WEB_RELOAD=false

# Security Configuration
# Require SSL/TLS for web interface
AEGISSCAN_WEB_HTTPS=false

# API Key for web interface access
AEGISSCAN_API_KEY=

# Proxy Configuration (optional)
# AEGISSCAN_PROXY_HTTP=http://proxy.example.com:8080
# AEGISSCAN_PROXY_HTTPS=https://proxy.example.com:8080

# Report Configuration
# Supported formats: html, pdf, json, csv
AEGISSCAN_REPORT_FORMAT=html

# Retention Configuration
# How long to keep scan results (in days, 0 = indefinite)
AEGISSCAN_RETENTION_DAYS=90

# Feature Flags
# Enable experimental features
AEGISSCAN_EXPERIMENTAL=false

# Enable banner grabbing
AEGISSCAN_ENABLE_BANNERS=true

# Enable TLS inspection
AEGISSCAN_ENABLE_TLS=true

# Enable external intelligence lookups
AEGISSCAN_ENABLE_EXTERNAL=true
